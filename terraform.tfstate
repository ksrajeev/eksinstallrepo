    "rendered_userdata": {
      "value": "MIME-Version: 1.0\nContent-Type: multipart/mixed; boundary=\"BOUNDARY\"\n\n--BOUNDARY\nContent-Type: application/node.eks.aws\n---\napiVersion: node.eks.aws/v1alpha1\nkind: NodeConfig\nspec:\n  cluster:\n    name: eks-cluster-v2\n    # NodeConfig will auto-discover endpoint and CA when only name is provided\n  kubelet:\n    config:\n      kind: KubeletConfiguration\n      apiVersion: kubelet.config.k8s.io/v1beta1\n      # Example: Pass extra flags like node labels or taints\n      registerWithTaints:\n        - key: \"workload\"\n          value: \"production\"\n          effect: \"NoSchedule\"\n    flags:\n      - \"--node-labels=env=prod,project=eks133\"\n\n--BOUNDARY\nContent-Type: text/x-shellscript; charset=\"us-ascii\"\n#!/bin/bash\necho \"Running custom post-install steps...\"\n# Your custom setup here (e.g., installing logging agents)\n\n--BOUNDARY--",
      "type": "string"
    },
